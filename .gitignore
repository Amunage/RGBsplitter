# Python bytecode and caches
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
env/
ENV/

# Python packaging outputs
build/
dist/
*.egg-info/
.eggs/
pip-wheel-metadata/

# Test, coverage, and tool caches
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.mypy_cache/
.ruff_cache/
.tox/
.nox/
.cache/

# development and project files
scripts/*
!scripts/build.bat
tests/
docs/

# PyInstaller outputs
*.manifest
*.toc
*.pkg

# Local environment and logs
.env
.env.*
*.local
*.log

# Helper script backups
.git_local_backup/

# Temporary files
*.tmp
*.temp
*.bak
*.swp

# OS and editor files
.DS_Store
Thumbs.db
desktop.ini
.idea/
.vscode/
